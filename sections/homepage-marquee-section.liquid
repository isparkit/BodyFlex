{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px  * 0.75);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding">
    <div class="custom-marquee">
      <div class="maruqee-track">
        {% for i in (1..3) %}
          {% for block in section.blocks %}
            <div class="marquee-item">
              {% if block.settings.icon_image != blank %}
                <img src="{{ block.settings.icon_image | img_url: 'master' }}" alt="icon">
              {% endif %}
              {% if block.settings.text != blank %}
                <h6>{{ block.settings.text }}</h6>
              {% endif %}
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Homepage Marquee Section",
  "tag": "section",
  "class": "section custom-marquee-cls",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "marquee_bar",
      "name": "Marquee Bar",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Homepage Marquee Section"
    }
  ]
}
{% endschema %}

<style>
  .custom-marquee-cls .custom-marquee {
    overflow: hidden;
  }
  .custom-marquee-cls .maruqee-track {
    display: flex;
    gap: 80px;
    animation: marquee 10s linear infinite;
    white-space: nowrap;
  }
  .custom-marquee-cls .marquee-item {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: center;
  }
  .custom-marquee-cls .marquee-item img {
    width: 24px;
    height: auto;
  }
  .custom-marquee-cls .marquee-item h6 {
    font-weight: 500;
    line-height: 1em;
    letter-spacing: 0;
    color: rgba(var(--color-foreground));
    text-transform: uppercase;
    margin: 0;
    text-box-edge: cap alphabetic;
    text-box-trim: trim-both;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0%);
    }
    100% {
      transform: translateX(-50%);
    }
  }
@media screen and (max-width: 767px) {
    .custom-marquee-cls .maruqee-track {
        gap: 30px;
    }   
    .custom-marquee-cls .marquee-item img {
        width: 18px;
    }
}
</style>
