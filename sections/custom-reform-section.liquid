{% schema %}
{
  "name": "Custom Reform Section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Reformly tager dig videre"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Over 10.000 kvinder deltog i vores 28-dages udfordring, og resultaterne taler for sig selv. Vi spurgte vores fællesskab, og her er, hvad de havde at sige:"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Statistic Block",
      "settings": [
        {
          "type": "text",
          "id": "percentage",
          "label": "Percentage",
          "default": "97%"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "tabte to buksestørrelser på 28 dage"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Custom Reform Section",
      "category": "Custom",
      "blocks": [
        { "type": "stat" },
        { "type": "stat" },
        { "type": "stat" }
      ]
    }
  ]
}
{% endschema %}

<section class="reformly-section">
  <div class="container">
    <h2 class="heading">{{ section.settings.heading }}</h2>
    <p class="subtext">{{ section.settings.subtext }}</p>

    <div class="stats-wrapper">
      {% for block in section.blocks %}
        <div class="stat-block">
          <div class="circle">{{ block.settings.percentage }}</div>
          <p class="description">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
.reformly-section {
  background-color: #eef0ff;
  padding: 60px 20px;
  text-align: center;
}
.reformly-section .container {
  max-width: 1200px;
  margin: 0 auto;
}
.heading {
  font-size: 28px;
  font-weight: 600;
  margin-bottom: 10px;
}
.subtext {
  font-size: 16px;
  margin-bottom: 40px;
  color: #333;
}
.stats-wrapper {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 30px;
}
.stat-block {
  flex: 1 1 200px;
  max-width: 220px;
  text-align: center;
}
.circle {
  background-color: #5a6cd8;
  color: white;
  font-size: 24px;
  font-weight: bold;
  width: 80px;
  height: 80px;
  line-height: 80px;
  border-radius: 50%;
  margin: 0 auto 10px auto;
}
.description {
  font-size: 14px;
  color: #111;
}

/* Mobile responsiveness */
@media (max-width: 768px) {
  .stats-wrapper {
    flex-direction: column;
    align-items: center;
  }
}
</style>
