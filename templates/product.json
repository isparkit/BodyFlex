        "custom_liquid_TtTTA4": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n  .custom-accordion {\n    width: 100%;\n    border-bottom: 1px solid #ddd;\n    margin-top: 10px;\n  }\n\n  .accordion-item {\n    border-top: 1px solid #ddd;\n  }\n\n  .accordion-header {\n    font-size: 15px;\n    font-weight: 600;\n    padding: 8px 0;\n    cursor: pointer;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    color: #000;\n  }\n\n  .accordion-content {\n    display: none;\n    padding: 6px 0;\n    font-size: 14px !important;\n    color: #444;\n    line-height: 1.4;\n    margin-top: 10px;\n  }\n\n  .accordion-content p {\n    font-size: 14px !important;\n  }\n\n  .accordion-item.active .accordion-content {\n    display: block;\n    margin-top: -20px;\n  }\n\n  .accordion-icon {\n    width: 8px;\n    height: 8px;\n    border-right: 2px solid rgba(0, 0, 0, 0.3);\n    border-bottom: 2px solid rgba(0, 0, 0, 0.3);\n    transform: rotate(45deg);\n    transition: transform 0.3s ease, border-color 0.3s ease;\n  }\n\n  .accordion-header:hover .accordion-icon {\n    border-right-color: rgba(0, 0, 0, 0.5);\n    border-bottom-color: rgba(0, 0, 0, 0.5);\n  }\n\n  .accordion-item.active .accordion-icon {\n    transform: rotate(-135deg);\n    border-right-color: rgba(0, 0, 0, 0.5);\n    border-bottom-color: rgba(0, 0, 0, 0.5);\n  }\n\n  .highlight-text {\n    font-weight: bold;\n    margin-top: 10px; /* Adjusted top margin to match spacing */\n    margin-bottom: 5px;\n    text-align: left;\n    padding: 0;\n    margin-left: 0;\n    font-size: 14px;\n    color: black; /* Text color set to black */\n  }\n</style>\n\n<div class=\"custom-accordion\">\n  <!-- Ny Sektion -->\n  <div class=\"accordion-item\">\n    <div class=\"accordion-header\" onclick=\"toggleAccordion(this)\">\n      Hvad er inkluderet?\n      <span class=\"accordion-icon\"></span>\n    </div>\n    <div class=\"accordion-content\">\n      <p>1 x BodyFlex Pilates Reformer</p>\n      <p>2 x BodyFlex træningselastikker</p>\n      <p>1 x Telefonholder</p>\n      <p>1 x Træningsmåtte</p>\n      <p>1 x Nedtællingsur</p>\n      <p>1 x 12-ugers digital træningsguide og plan </p>\n    </div>\n  </div>\n\n  <!-- Tilfredshedsgaranti -->\n  <div class=\"accordion-item\">\n    <div class=\"accordion-header\" onclick=\"toggleAccordion(this)\">\n      Tilfredshedsgaranti\n      <span class=\"accordion-icon\"></span>\n    </div>\n    <div class=\"accordion-content\">\n      <p>Vi tilbyder 30 dages tilfredshedsgaranti, så du kan prøve vores produkt risikofrit. Hvis du ikke er tilfreds, får du pengene tilbage – nemt og enkelt.</p>\n    </div>\n  </div>\n\n  <!-- Levering -->\n  <div class=\"accordion-item\">\n    <div class=\"accordion-header\" onclick=\"toggleAccordion(this)\">\n      Levering\n      <span class=\"accordion-icon\"></span>\n    </div>\n    <div class=\"accordion-content\">\n      <p>Vi bestræber os på at sende din ordre den samme dag som du bestiller. Derfor kan du forvente at få din pakke inden for 1-3 hverdage.</p>\n    </div>\n  </div>\n</div>\n\n<script>\n  function toggleAccordion(header) {\n    var item = header.parentElement;\n    item.classList.toggle(\"active\");\n  }\n</script>"
