hi321 {\n      flex-direction: row; /* Keep everything in a row (left finger, logo, and right text) */\n      justify-content: center; /* Center the content */\n      padding-left: 10px; /* Further reduced padding */\n    }\n\n    .footer-section-abc123 .trustpilot-logo-ghi321 .finger-icon {\n      font-size: 16px; /* Slightly smaller finger emoji on mobile */\n      margin-right: 5px; /* Reduced margin */\n    }\n\n    .footer-section-abc123 .trustpilot-logo-ghi321 img {\n      width: 100px;  /* Make logo smaller on mobile */\n    }\n\n    .footer-section-abc123 .trustpilot-logo-ghi321 .trustpilot-text {\n      font-size: 12px; /* Smaller text on mobile */\n      margin-left: 5px; /* Reduced space between logo and text */\n    }\n  }\n</style>\n\n<div class=\"footer-section-abc123\">\n  <!-- Payment Icons Section -->\n  <ul class=\"inline-list payment-icons-xyz789\">\n    {% assign enabled_payment_types = 'visa,dankort,master,anyday, google_pay, apple_pay, paypal,' | remove: ' ' | split: ',' %}\n    {% for type in enabled_payment_types %}\n      <li class=\"icon--payment-pqr456\">\n        {{ type | payment_type_svg_tag }}\n      </li>\n    {% endfor %}\n  </ul>\n\n  <!-- Trustpilot Logo, Finger Emoji, and Review Text Section -->\n  <div class=\"trustpilot-logo-ghi321\">\n    <!-- Finger emoji to the left -->\n    <span class=\"finger-icon\">👉</span>\n\n    <!-- Trustpilot Logo -->\n    <a href=\"https://dk.trustpilot.com/review/bodyflex.dk\" target=\"_blank\">\n      <img class=\"trustpilot-image\" src=\"https://cdn.trustpilot.net/brand-assets/4.1.0/stars/stars-4.5.svg\" alt=\"Trustpilot logo\">\n    </a>\n\n    <!-- Text on the right -->\n    <span class=\"trustpilot-text\">Fremragende</span>\n  </div>\n\n  <!-- Description Tabs Section -->\n  <div class=\"description-tabs\">\n    <!-- Your description tabs code goes here -->\n  </div>\n</div>"
