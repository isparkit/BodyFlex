      "blocks": {
        "slide_XxCtiM": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Super godt produkt",
            "text": "Jeg har brugt den i 2 uger nu og jeg kan virkelig mærke forskellen, jeg er blevet mere smidig i kroppen og den har øget min mobilitet. Kan helt klart anbefale den. 😊",
            "author_date": "Kristina V."
          }
        },
        "slide_hXHfEV": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Genialt produkt",
            "text": "Den fylder næsten ingenting og klappes nemt sammen igen efter brug. Jeg føler mig langt mere smidig og tilpas i min egen krop efter jeg er begyndt at inkludere den i min morgen rutine.",
            "author_date": "Alex F."
          }
        },
        "slide_6aChg4": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Virkelig godt produkt",
            "text": "Jeg har indtil videre brugt min hver dag og mine rygsmerter er allerede mindsket. Hurtig levering modtog min dagen efter jeg havde bestilt.",
            "author_date": "Josephine O."
          }
        },
        "slide_nW4kfx": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Jeg har haft Bodyflex Pilates Reformer i et par uger nu",
            "text": "Efter et par ugers brug er mine muskelspændinger og min stivhed nærmest forsvundet. Varm anbefaling herfra.",
            "author_date": "Casper N."
          }
        },
        "slide_hKtK98": {
          "type": "slide",
          "settings": {
            "stars_count": 5,
            "heading": "Fantastisk service og kvalitet!",
            "text": "Jeg har haft en rigtig god oplevelse med Bodyflex.dk! Lynhurtig levering, og BodyFlex Pilates Reformer lever fuldt ud op til forventningerne og er super god kvalitet.",
            "author_date": "Ismail K."
          }
        }
      },
