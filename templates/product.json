yment-icons1\">\n      {% assign enabled_payment_types = 'mobilepay,visa,dankort,master,anyday,google_pay,apple_pay,paypal,' | remove: ' ' | split: ',' %}\n      {% for type in enabled_payment_types %}\n        <li class=\"icon--payment1\">\n          {{ type | payment_type_svg_tag }}\n        </li>\n      {% endfor %}\n    </ul>\n\n    <!-- Trustpilot Logo, \"Fremragende\" Text, and Stars Section -->\n    <div class=\"trustpilot-logo\">\n      <span class=\"trustpilot-text\">Fremragende</span>\n\n      <!-- Clickable 4.5 Stars -->\n      <a href=\"https://dk.trustpilot.com/review/bodyflex.dk\" target=\"_blank\">\n        <img class=\"trustpilot-stars\" src=\"https://cdn.trustpilot.net/brand-assets/4.1.0/stars/stars-4.5.svg\" alt=\"Trustpilot 4.5 stars\">\n      </a>\n\n      <!-- Clickable One-Star Trustpilot Logo -->\n      <a href=\"https://dk.trustpilot.com/review/bodyflex.dk\" target=\"_blank\">\n        <img class=\"trustpilot-one-star\" src=\"https://1000logos.net/wp-content/uploads/2022/10/Trustpilot-Logo-500x281.png\" alt=\"Trustpilot logo\">\n      </a>\n    </div>\n\n    <!-- Description Tabs Section -->\n    <div class=\"description-tabs\">\n      <!-- Your description tabs code goes here -->\n    </div>\n  </div>\n</a>"
